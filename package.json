  "scripts": {
    "test": "jest",
    "test:e2e": "playwright test",
    "test:storybook:e2e": "playwright test -c playwright.storybook.config.ts",
    "test:storybook:e2e:ci": "npm run build-storybook && npm run test:storybook:e2e",
    "coverage": "jest --coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prerelease:enter": "changeset pre enter next",
    "prerelease:exit": "changeset pre exit",
    "prepublishOnly": "npm run build:rollup",
    "test:shard": "jest --shard=$JEST_SHARD",
    "test:watch": "jest --watch",
    "clean": "rimraf dist",
    "chromatic": "chromatic --exit-zero-on-changes",
    "patch": "npm version patch",
    "sb": "node ./scripts/storybook-dev.cjs",
    "storybook": "node ./scripts/storybook-dev.cjs",
    "storybook:server": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-css": "rollup -c rollup-css.config.js",
    "generate-tokens": "tsx ./src/tokenGen/index.js",
    "generate-tokens:watch": "tsx watch ./src/tokenGen/index.js",
    "bundle-tokens": "rollup --config rollup-tokens.config.js",
    "compile-components": "rollup -c rollup.config.cjs",
    "process-components": "node scripts/process-components.cjs",
    "prebuild": "npm run test && npm run clean",
    "build:generate-exports": "node scripts/generate-exports.cjs",
    "build:css": "npm run generate-tokens && npm run bundle-tokens && npm run build-css",
    "build:components": "npm run compile-components && npm run process-components",
    "build:rollup": "NODE_OPTIONS='--max-old-space-size=8192' npm run build:rollup:process",
    "build:rollup:process": "npm run clean && (npm run build:css & npm run build:components & wait) && npm run build:generate-exports",
    "compile-components:esbuild": "node build-components.cjs",
    "check:types": "tsc --noEmit",
    "check:exports": "node scripts/generate-exports.cjs --check",
    "validate:changesets": "node scripts/validate-changesets.mjs",
    "build-components:esbuild": "npm run compile-components:esbuild && npm run process-components",
    "build:esbuild": "npm run prebuild && npm run build:css && npm run build-components:esbuild",
    "release": "npm publish --access public",
    "release:ci": "npm publish --access public --provenance",
    "lint": "eslint . --fix && stylelint \"**/*.{css,scss,sass}\" --fix",
    "lint:staged": "lint-staged",
    "update-rad": "npm update @radui/ui",
    "setup:dependencies": "npm install --force",
    "setup": "npm run setup:dependencies"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "jest --findRelatedTests --passWithNoTests"
    ],
    "{src,e2e,scripts,test-utils,.storybook}/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{css,scss,sass}": [
      "stylelint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rad-ui/ui.git"
  },
