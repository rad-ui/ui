{
  "name": "@radui/ui",
  "version": "0.5.0",
  "description": "",
  "main": "dist",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./themes/default.css": "./dist/themes/default.css",
    "./themes/baremetal.css": "./dist/themes/baremetal.css",
    "./themes/tailwind-presets/default.js": "./dist/themes/tailwind-presets/default.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "test": "jest",
    "test:e2e": "playwright test",
    "test:storybook:e2e": "playwright test -c playwright.storybook.config.ts",
    "test:storybook:e2e:ci": "npm run build-storybook && npm run test:storybook:e2e",
    "coverage": "jest --coverage",
    "coverage:ci": "jest --coverage --config jest.coverage-ci.config.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prerelease:enter": "changeset pre enter next",
    "prerelease:exit": "changeset pre exit",
    "prepublishOnly": "npm run build:rollup",
    "test:shard": "jest --shard=$JEST_SHARD",
    "test:watch": "jest --watch",
    "clean": "rimraf dist",
    "chromatic": "chromatic --exit-zero-on-changes",
    "patch": "npm version patch",
    "sb": "node ./scripts/storybook-dev.cjs",
    "storybook": "node ./scripts/storybook-dev.cjs",
    "storybook:server": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-css": "rollup -c rollup-css.config.js",
    "generate-tokens": "tsx ./src/tokenGen/index.js",
    "generate-tokens:watch": "tsx watch ./src/tokenGen/index.js",
    "bundle-tokens": "rollup --config rollup-tokens.config.js",
    "compile-components": "rollup -c rollup.config.cjs",
    "process-components": "node scripts/process-components.cjs",
    "prebuild": "npm run test && npm run clean",
    "build:generate-exports": "node scripts/generate-exports.cjs",
    "build:css": "npm run generate-tokens && npm run bundle-tokens && npm run build-css",
    "build:components": "npm run compile-components && npm run process-components",
    "build:rollup": "NODE_OPTIONS='--max-old-space-size=8192' npm run build:rollup:process",
    "build:rollup:process": "npm run clean && (npm run build:css & npm run build:components & wait) && npm run build:generate-exports",
    "compile-components:esbuild": "node build-components.cjs",
    "check:types": "tsc --noEmit",
    "check:exports": "node scripts/generate-exports.cjs --check",
    "check:api-surface": "node scripts/check-public-api-surface.mjs --check",
    "validate:changesets": "node scripts/validate-changesets.mjs",
    "build-components:esbuild": "npm run compile-components:esbuild && npm run process-components",
    "build:esbuild": "npm run prebuild && npm run build:css && npm run build-components:esbuild",
    "release": "npm publish --access public",
    "release:ci": "npm publish --access public --provenance",
    "lint": "eslint . --fix && stylelint \"**/*.{css,scss,sass}\" --fix",
    "lint:staged": "lint-staged",
    "update-rad": "npm update @radui/ui",
    "setup:dependencies": "npm install --force",
    "setup": "npm run setup:dependencies",
    "prepare": "husky install",
    "check:docs-examples": "pnpm --dir docs check:examples"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "jest --findRelatedTests --passWithNoTests"
    ],
    "{src,e2e,scripts,test-utils,.storybook}/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{css,scss,sass}": [
      "stylelint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rad-ui/ui.git"
  },
  "bugs": {
    "url": "https://github.com/rad-ui/ui/issues"
  },
  "author": "Pranay Kothapalli",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@babel/eslint-parser": "7.26.10",
    "@babel/preset-env": "7.29.3",
    "@babel/preset-react": "7.22.15",
    "@babel/preset-typescript": "^7.24.7",
    "babel-loader": "^10.0.0",
    "@changesets/cli": "^2.29.7",
    "@playwright/test": "^1.56.0",
    "@rollup/plugin-alias": "5.1.0",
    "@rollup/plugin-babel": "6.0.4",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "11.1.6",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-links": "10.3.6",
    "@storybook/react-webpack5": "10.3.6",
    "@storybook/testing-library": "0.2.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.1",
    "autoprefixer": "10.4.15",
    "axe-core": "^4.10.3",
    "babel-plugin-module-resolver": "5.0.2",
    "esbuild": "^0.28.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "16.6.2",
    "eslint-plugin-promise": "6.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "8.0.3",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "lint-staged": "^16.1.2",
    "lucide-react": "^0.575.0",
    "mkdirp": "^3.0.1",
    "postcss": "8.5.13",
    "postcss-loader": "^8.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "6.0.1",
    "rollup": "4.60.0",
    "rollup-plugin-banner2": "1.3.0",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.77.2",
    "sass-loader": "16.0.4",
    "storybook": "10.3.6",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-tailwindcss": "^0.0.7",
    "tailwindcss": "3.4.1",
    "ts-jest": "29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "eslint-plugin-storybook": "10.3.6",
    "@storybook/addon-docs": "10.3.6"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "overrides": {
    "eslint-config-standard": {
      "eslint": "$eslint"
    }
  }
}
